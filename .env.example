# 复制为 .env 后按需修改：cp .env.example .env
#
# 浏览器访问端口（开发 / vite preview 对外监听）
METAPOSTGUI_WEB_PORT=5173
# 开发默认 127.0.0.1；PM2 prod 会默认改为 0.0.0.0 便于局域网访问
# 如需强制指定再取消注释：
# METAPOSTGUI_WEB_HOST=127.0.0.1

# 编译 API 端口（仅本机回环，不应对外暴露；由 Vite / Nginx 反代 /api）
# 默认 18765，避开常见 Node 服务占用的 8765 等端口
METAPOSTGUI_API_PORT=18765
# 请勿改为 0.0.0.0；API 应只监听 127.0.0.1
METAPOSTGUI_API_HOST=127.0.0.1

# 端口被占用时自动尝试后续端口（每种最多尝试次数）
METAPOSTGUI_PORT_TRIES=20

# 可选：额外 CORS 来源（逗号分隔）。未设时根据 WEB_PORT 自动生成 localhost 来源
# 这里影响 API CORS；公网域名建议写完整 origin。
# METAPOSTGUI_CORS_ORIGINS=https://mpost.vanabel.cn

# 可选：Vite preview 允许的 Host（Cloudflare Tunnel / 反代域名）
# 只写 hostname；多个用逗号分隔。
# METAPOSTGUI_ALLOWED_HOSTS=mpost.vanabel.cn

# Docker Compose 宿主机映射端口；容器内仍使用 METAPOSTGUI_WEB_PORT。
# 例如设为 19904 时，映射为 NAS:19904 -> container:18080。
# METAPOSTGUI_DOCKER_WEB_PORT=19904
