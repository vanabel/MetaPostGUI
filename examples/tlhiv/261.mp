let beginbox_ = OLD_beginbox_;
let boxit     = OLD_boxit;
let sizebox_  = OLD_sizebox_;
let clearb_   = OLD_clearb_;
extra_beginfig := "";
extra_:= "";
input boxes;
draw (0,0) -- (5cm,0) withcolor red;
boxjoin(b.c - a.c = (1cm,0));
boxit a (btex a etex);
boxit b (btex b etex);
boxit c (btex c etex);
boxit d (btex d etex);
boxit e (btex e etex);
drawboxed(a,b,c,d,e);
endfig;
